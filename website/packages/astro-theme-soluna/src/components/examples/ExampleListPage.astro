---
import Menubar from '../Menubar.astro'

interface ExampleItem {
  id: string
  title: string
  entry: string
}

interface Props {
  examples: ExampleItem[]
}

const { examples } = Astro.props
const basePath = import.meta.env.BASE_URL
---

<section class="section">
  <div class="section-header">
    <div>
      <h1 class="section-title">Examples</h1>
      <p class="section-subtitle">Gallery of Soluna test entries.</p>
    </div>
  </div>
</section>

<Menubar>
  <a href={basePath}>home</a>
</Menubar>

<ul class="example-index">
  {examples.map(example => (
    <li>
      <a href={`${basePath}examples/${example.id}/`}>{example.title}</a>
      <code>{example.entry}</code>
    </li>
  ))}
</ul>
